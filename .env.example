# ─── App ───────────────────────────────────────────
NODE_ENV=production
PORT=8080
APP_URL=https://api.yourchatapp.com
CLIENT_URL=https://yourchatapp.com

# ─── Database (MySQL) ──────────────────────────────
DB_HOST=your-rds-or-db-host.com
DB_PORT=3306
DB_NAME=chat_system_prod
DB_USER=chat_prod_user
DB_PASSWORD=StrongPasswordHere!
DB_DIALECT=mysql

# ─── Redis ─────────────────────────────────────────
REDIS_HOST=your-redis-host.com
REDIS_PORT=6379
REDIS_PASSWORD=StrongRedisPasswordHere!

# ─── JWT ───────────────────────────────────────────
JWT_ACCESS_SECRET=super_long_random_256bit_secret_here
JWT_REFRESH_SECRET=another_super_long_random_256bit_secret_here

# ─── Cloudinary ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email (Real SMTP — SendGrid / SES) ────────────
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=465
MAIL_USER=apikey
MAIL_PASS=your_sendgrid_api_key
MAIL_FROM=noreply@yourchatapp.com

# ─── Logging ───────────────────────────────────────
LOG_LEVEL=error