# ─── App ───────────────────────────────────────────
NODE_ENV=production
PORT=8080
APP_URL=https://api.yourchatapp.com
CLIENT_URL=https://yourchatapp.com

# ─── Database (MySQL) ──────────────────────────────
DB_HOST=your-rds-or-db-host.com
DB_PORT=3306
DB_NAME=chat_system_prod
DB_USER=chat_prod_user
DB_PASSWORD=StrongPasswordHere!
DB_DIALECT=mysql

# ─── Redis ─────────────────────────────────────────
REDIS_URL=your-redis-host.com

# ─── JWT ───────────────────────────────────────────
JWT_ACCESS_SECRET=super_long_random_256bit_secret_here
JWT_REFRESH_SECRET=another_super_long_random_256bit_secret_here

# ─── Cloudinary ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
USER_FOLDER=your_user_profile_folder
GROUP_FOLDER=your_group_profile_folder
MESSAGE_FOLDER=your_messages_media_folder

# ─── Email (Real SMTP — SendGrid / SES) ────────────
MAIL_PASS=your_app_password
MAIL_FROM=your_registered_gmail

# ─── Logging ───────────────────────────────────────
LOG_LEVEL=error